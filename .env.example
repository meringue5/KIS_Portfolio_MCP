# ──────────────────────────────────────────────────────
# KIS MCP Server 환경변수 템플릿
# 이 파일을 복사해서 .env를 만들고 실제 값을 채우세요.
# .env는 절대 커밋하지 않습니다 (.gitignore에 포함됨)
# ──────────────────────────────────────────────────────

# ── RIA (위험자산 일임) ──
KIS_APP_KEY_RIA=
KIS_APP_SECRET_RIA=
KIS_CANO_RIA=
KIS_ACNT_PRDT_CD_RIA=01

# ── ISA ──
KIS_APP_KEY_ISA=
KIS_APP_SECRET_ISA=
KIS_CANO_ISA=
KIS_ACNT_PRDT_CD_ISA=01

# ── IRP 퇴직연금 ──
KIS_APP_KEY_IRP=
KIS_APP_SECRET_IRP=
KIS_CANO_IRP=
KIS_ACNT_PRDT_CD_IRP=29

# ── 연금저축 ──
KIS_APP_KEY_PENSION=
KIS_APP_SECRET_PENSION=
KIS_CANO_PENSION=
KIS_ACNT_PRDT_CD_PENSION=22

# ── 일반 위탁 ──
KIS_APP_KEY_BROKERAGE=
KIS_APP_SECRET_BROKERAGE=
KIS_CANO_BROKERAGE=
KIS_ACNT_PRDT_CD_BROKERAGE=01

# ── MotherDuck (DuckDB 클라우드) ──
# https://app.motherduck.com → Settings → Tokens
KIS_DB_MODE=motherduck
MOTHERDUCK_DATABASE=kis_portfolio
MOTHERDUCK_TOKEN=

# ── 로컬 런타임 경로 ──
# 상대경로는 프로젝트 루트 기준입니다.
# legacy 토큰 파일 migration 경로: var/tokens/token_{CANO}.json
# local 모드 DB: var/local/kis_portfolio.duckdb
KIS_DATA_DIR=var

# ── 공통 ──
KIS_ACCOUNT_TYPE=REAL
KIS_ENABLE_ORDER_TOOLS=false
# KIS access token DB 암호화 키
# 생성 예시:
# uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
KIS_TOKEN_ENCRYPTION_KEY=

# ── Remote MCP resource server ──
# local Claude Desktop MCP에는 필요 없습니다.
# ChatGPT 호환/운영 권장값: oauth
# 빠른 bearer 실험이 필요하면 bearer로 바꾸고 KIS_REMOTE_AUTH_TOKEN을 채우세요.
KIS_REMOTE_AUTH_MODE=oauth
# bearer fallback 전용
KIS_REMOTE_AUTH_TOKEN=
KIS_AUTH_ISSUER_URL=
KIS_RESOURCE_SERVER_URL=
KIS_AUTH_REQUIRED_SCOPES=mcp:read
# auth discovery가 광고할 scope. 기본값: mcp:read offline_access
KIS_AUTH_ALLOWED_SCOPES=
# opaque token digest 검증용 shared secret
KIS_AUTH_TOKEN_PEPPER=
KIS_REMOTE_HOST=0.0.0.0
KIS_REMOTE_PORT=8000

# ── OAuth auth server ──
KIS_AUTH_BASE_URL=
KIS_AUTH_OWNER_EMAILS=
KIS_AUTH_SESSION_SECRET=
KIS_AUTH_CLAUDE_CLIENT_ID=
KIS_AUTH_CLAUDE_CLIENT_SECRET=
# 기본값:
# https://claude.ai/api/mcp/auth_callback,https://claude.com/api/mcp/auth_callback
KIS_AUTH_CLAUDE_REDIRECT_URIS=
# 기본값:
# https://chatgpt.com/connector/oauth/,https://chatgpt.com/connector_platform_oauth_redirect
KIS_AUTH_DYNAMIC_CLIENT_REDIRECT_PREFIXES=
KIS_OAUTH_GOOGLE_CLIENT_ID=
KIS_OAUTH_GOOGLE_CLIENT_SECRET=
KIS_OAUTH_GITHUB_CLIENT_ID=
KIS_OAUTH_GITHUB_CLIENT_SECRET=

# ── Cloud Run / Scheduler deployment (optional) ──
GOOGLE_CLOUD_PROJECT=
# Optional fallback used when KIS_CLOUD_SCHEDULER_INVOKER_SERVICE_ACCOUNT is omitted.
GOOGLE_CLOUD_PROJECT_NUMBER=
KIS_DEPLOY_REGION=asia-northeast3

# Cloud Run Job for domestic order history collection
KIS_BATCH_JOB_NAME=kis-portfolio-domestic-order-history
KIS_CLOUD_RUN_BATCH_SERVICE_ACCOUNT=
KIS_CLOUD_RUN_BATCH_TASK_TIMEOUT=1800s
# Keep 0 for append-only order history to avoid duplicate writes from infra retries.
KIS_CLOUD_RUN_BATCH_MAX_RETRIES=0

# Cloud Scheduler trigger for the batch job
KIS_BATCH_SCHEDULER_NAME=kis-portfolio-domestic-order-history-1535
KIS_CLOUD_SCHEDULER_REGION=asia-northeast3
KIS_BATCH_ORDER_HISTORY_SCHEDULE=35 15 * * 1-5
KIS_BATCH_ORDER_HISTORY_TIME_ZONE=Asia/Seoul
KIS_CLOUD_SCHEDULER_INVOKER_SERVICE_ACCOUNT=
