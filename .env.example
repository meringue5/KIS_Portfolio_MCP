# ──────────────────────────────────────────────────────
# KIS MCP Server 환경변수 템플릿
# 이 파일을 복사해서 .env를 만들고 실제 값을 채우세요.
# .env는 절대 커밋하지 않습니다 (.gitignore에 포함됨)
# ──────────────────────────────────────────────────────

# ── RIA (위험자산 일임, CANO: ..., ACNT_PRDT_CD: 01) ──
KIS_APP_KEY_RIA=
KIS_APP_SECRET_RIA=
KIS_CANO_RIA=

# ── ISA (CANO: ..., ACNT_PRDT_CD: 01) ──
KIS_APP_KEY_ISA=
KIS_APP_SECRET_ISA=
KIS_CANO_ISA=

# ── IRP 퇴직연금 (CANO: ..., ACNT_PRDT_CD: 29) ──
KIS_APP_KEY_IRP=
KIS_APP_SECRET_IRP=
KIS_CANO_IRP=

# ── 연금저축 (CANO: ..., ACNT_PRDT_CD: 22) ──
KIS_APP_KEY_PENSION=
KIS_APP_SECRET_PENSION=
KIS_CANO_PENSION=

# ── 일반 위탁 (CANO: ..., ACNT_PRDT_CD: 01) ──
KIS_APP_KEY_BROKERAGE=
KIS_APP_SECRET_BROKERAGE=
KIS_CANO_BROKERAGE=

# ── MotherDuck (DuckDB 클라우드) ──
# https://app.motherduck.com → Settings → Tokens
KIS_DB_MODE=motherduck
MOTHERDUCK_DATABASE=kis_portfolio
MOTHERDUCK_TOKEN=

# ── 로컬 런타임 경로 ──
# 상대경로는 프로젝트 루트 기준입니다.
# 토큰 캐시: var/tokens/token_{CANO}.json
# local 모드 DB: var/local/kis_portfolio.duckdb
KIS_DATA_DIR=var

# ── 공통 ──
KIS_ACCOUNT_TYPE=REAL
